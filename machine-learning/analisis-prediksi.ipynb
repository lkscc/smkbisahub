# Cell 1: Import Library
import boto3
import pandas as pd
import io

# Cell 2: Konfigurasi S3 via Boto3
# TODO: LKS CHALLENGE (MODUL 3)
# Masukkan nama S3 Bucket yang telah Anda buat di Modul 2
bucket_name = 'lks-sertifikat-smk-MASUKKAN_NOMOR_PESERTA'
file_key = 'data-magang.csv'

print(f"Mencoba mengambil {file_key} dari bucket {bucket_name}...")

# Cell 3: Mengambil data tanpa akses internet publik (menggunakan VPC Endpoint)
try:
    s3_client = boto3.client('s3')
    response = s3_client.get_object(Bucket=bucket_name, Key=file_key)
    status = response.get("ResponseMetadata", {}).get("HTTPStatusCode")

    if status == 200:
        print("Koneksi berhasil! Data berhasil diunduh via VPC Endpoint S3.")
        df = pd.read_csv(io.BytesIO(response['Body'].read()))
        display(df.head())
    else:
        print("Gagal mengambil data.")
        
except Exception as e:
    print("ERROR KONEKSI:")
    print("Jika Notebook berputar (loading) terlalu lama atau mendapat error 'Timeout',")
    print("pastikan VPC Endpoint (lks-vpce-s3) dan Route Table Anda sudah dikonfigurasi dengan benar!")
    print(e)
